@inject ITicketDisplayService DisplayService
@inject IUserApiService UserService

<div class="search-filter">
    <div class="search-filter__field search-filter__field--keyword">
        <label class="form-label" for="keyword">Search</label>
        <div class="search-filter__input-group">
            <input id="keyword"
                   class="form-control"
                   placeholder="Search title or description..."
                   @bind="keyword"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />
            <button type="button" class="btn btn-primary" @onclick="ApplyFilter">Search</button>
        </div>
    </div>

    <div class="search-filter__controls">
        <div class="search-filter__field">
            <label class="form-label" for="status">Status</label>
            <select id="status" class="form-select" value="@status" @onchange="OnStatusChanged">
                @foreach (var option in DisplayService.GetStatusFilterOptions())
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="search-filter__field">
            <label class="form-label" for="priority">Priority</label>
            <select id="priority" class="form-select" value="@priority" @onchange="OnPriorityChanged">
                @foreach (var option in DisplayService.GetPriorityFilterOptions())
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="search-filter__field">
            <label class="form-label" for="assignee">Assignee</label>
            <select id="assignee" class="form-select" value="@assigneeSelection" @onchange="OnAssigneeChanged">
                <option value="all">All Assignees</option>
                <option value="unassigned">Unassigned</option>
                @foreach (var user in users)
                {
                    <option value="@user.Id">@user.Name</option>
                }
            </select>
        </div>

        <div class="search-filter__field">
            <label class="form-label" for="sortBy">Sort By</label>
            <select id="sortBy" class="form-select" value="@sortBy" @onchange="OnSortByChanged">
                @foreach (var option in DisplayService.GetSortByOptions())
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="search-filter__field">
            <label class="form-label" for="sortDirection">Order</label>
            <select id="sortDirection" class="form-select" value="@sortDirection" @onchange="OnSortDirectionChanged">
                @foreach (var option in DisplayService.GetSortDirectionOptions())
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? InitialKeyword { get; set; }
    [Parameter] public string? InitialStatus { get; set; }
    [Parameter] public string? InitialPriority { get; set; }
    [Parameter] public string? InitialAssigneeSelection { get; set; }
    [Parameter] public string? InitialSortBy { get; set; }
    [Parameter] public string? InitialSortDirection { get; set; }
    [Parameter] public EventCallback<TicketSearchCriteria> OnSearch { get; set; }

    private readonly List<UserDto> users = [];
    private string keyword = string.Empty;
    private string status = "All";
    private string priority = "All";
    private string assigneeSelection = "all";
    private string sortBy = "CreatedAt";
    private string sortDirection = "desc";

    protected override async Task OnInitializedAsync()
    {
        users.AddRange(await UserService.GetUsersAsync());
    }

    protected override void OnParametersSet()
    {
        keyword = InitialKeyword ?? string.Empty;
        status = string.IsNullOrWhiteSpace(InitialStatus) ? "All" : InitialStatus;
        priority = string.IsNullOrWhiteSpace(InitialPriority) ? "All" : InitialPriority;
        assigneeSelection = string.IsNullOrWhiteSpace(InitialAssigneeSelection) ? "all" : InitialAssigneeSelection;
        sortBy = string.IsNullOrWhiteSpace(InitialSortBy) ? "CreatedAt" : InitialSortBy;
        sortDirection = string.IsNullOrWhiteSpace(InitialSortDirection) ? "desc" : InitialSortDirection;
    }

    private TicketSearchCriteria BuildCriteria()
    {
        int? assignedToId = null;
        var unassignedOnly = false;

        if (assigneeSelection == "unassigned")
        {
            unassignedOnly = true;
        }
        else if (assigneeSelection != "all" && int.TryParse(assigneeSelection, out var userId))
        {
            assignedToId = userId;
        }

        return new TicketSearchCriteria
        {
            Keyword = keyword,
            Status = status,
            Priority = priority,
            AssignedToId = assignedToId,
            UnassignedOnly = unassignedOnly,
            SortBy = sortBy,
            SortDirection = sortDirection
        };
    }

    private async Task ApplyFilter() =>
        await OnSearch.InvokeAsync(BuildCriteria());

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        status = e.Value?.ToString() ?? "All";
        await ApplyFilter();
    }

    private async Task OnPriorityChanged(ChangeEventArgs e)
    {
        priority = e.Value?.ToString() ?? "All";
        await ApplyFilter();
    }

    private async Task OnAssigneeChanged(ChangeEventArgs e)
    {
        assigneeSelection = e.Value?.ToString() ?? "all";
        await ApplyFilter();
    }

    private async Task OnSortByChanged(ChangeEventArgs e)
    {
        sortBy = e.Value?.ToString() ?? "CreatedAt";
        await ApplyFilter();
    }

    private async Task OnSortDirectionChanged(ChangeEventArgs e)
    {
        sortDirection = e.Value?.ToString() ?? "desc";
        await ApplyFilter();
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await ApplyFilter();
        }
    }
}
