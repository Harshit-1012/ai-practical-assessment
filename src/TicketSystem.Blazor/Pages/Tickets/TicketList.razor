@page "/tickets"
@inject ITicketApiService TicketService
@inject ITicketDisplayService DisplayService
@inject INotificationService Notifications
@inject NavigationManager Navigation

<PageTitle>Tickets</PageTitle>

<div class="page-header">
    <div>
        <h1>Support Tickets</h1>
        <p class="page-subtitle">Track, search, and manage support requests</p>
    </div>
    <button type="button" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/tickets/create"))">
        + New Ticket
    </button>
</div>

<SearchFilter OnSearch="HandleSearch"
              InitialKeyword="@currentKeyword"
              InitialStatus="@currentStatus"
              InitialPriority="@currentPriority"
              InitialAssigneeSelection="@currentAssigneeSelection"
              InitialSortBy="@currentSortBy"
              InitialSortDirection="@currentSortDirection" />

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-error">@errorMessage</div>
}

<LoadingSpinner IsLoading="isLoading" Message="Loading tickets..." />

@if (!isLoading)
{
    if (tickets.Count == 0)
    {
        <EmptyState Title="No tickets found"
                    Description="Try adjusting your search or create a new support ticket."
                    Icon="📋">
            <button type="button" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/tickets/create"))">
                Create Ticket
            </button>
        </EmptyState>
    }
    else
    {
        <div class="ticket-grid">
            @foreach (var ticket in tickets)
            {
                <article class="ticket-card" @onclick="@(() => Navigation.NavigateTo($"/tickets/{ticket.Id}"))" role="button" tabindex="0">
                    <div class="ticket-card__header">
                        <span class="ticket-card__id">#@ticket.Id</span>
                        <div class="ticket-card__badges">
                            <StatusBadge Status="@ticket.Status" />
                            <PriorityBadge Priority="@ticket.Priority" />
                        </div>
                    </div>
                    <h2 class="ticket-card__title">@ticket.Title</h2>
                    <p class="ticket-card__description">@ticket.Description</p>
                    <footer class="ticket-card__footer">
                        <span>@DisplayService.GetAssigneeDisplay(ticket.AssignedToName)</span>
                        <span>@DisplayService.FormatRelativeDate(ticket.CreatedAt)</span>
                    </footer>
                </article>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="pagination" aria-label="Ticket list pagination">
                <button type="button"
                        class="btn btn-secondary pagination__nav"
                        disabled="@(currentPage <= 1)"
                        @onclick="@(() => GoToPageAsync(currentPage - 1))">
                    Previous
                </button>

                <div class="pagination__pages">
                    @for (var page = 1; page <= totalPages; page++)
                    {
                        var pageNumber = page;
                        <button type="button"
                                class="pagination__page @(pageNumber == currentPage ? "pagination__page--active" : string.Empty)"
                                aria-current="@(pageNumber == currentPage ? "page" : null)"
                                @onclick="@(() => GoToPageAsync(pageNumber))">
                            @pageNumber
                        </button>
                    }
                </div>

                <button type="button"
                        class="btn btn-secondary pagination__nav"
                        disabled="@(currentPage >= totalPages)"
                        @onclick="@(() => GoToPageAsync(currentPage + 1))">
                    Next
                </button>
            </nav>
        }

        <p class="pagination__summary">
            Showing page @currentPage of @totalPages (@totalCount ticket@(totalCount == 1 ? string.Empty : "s"))
        </p>
    }
}

@code {
    private readonly List<TicketDto> tickets = [];
    private bool isLoading = true;
    private string? errorMessage;
    private string? currentKeyword;
    private string? currentStatus;
    private string? currentPriority;
    private string? currentAssigneeSelection;
    private string? currentSortBy;
    private string? currentSortDirection;
    private int currentPage = TicketSearchCriteria.DefaultPageNumber;
    private int pageSize = TicketSearchCriteria.DefaultPageSize;
    private int totalCount;
    private int totalPages;

    protected override async Task OnInitializedAsync() => await LoadTicketsAsync();

    private async Task HandleSearch(TicketSearchCriteria criteria)
    {
        currentKeyword = criteria.Keyword;
        currentStatus = criteria.Status;
        currentPriority = criteria.Priority;
        currentSortBy = criteria.SortBy;
        currentSortDirection = criteria.SortDirection;
        currentAssigneeSelection = criteria.UnassignedOnly
            ? "unassigned"
            : criteria.AssignedToId?.ToString() ?? "all";
        currentPage = TicketSearchCriteria.DefaultPageNumber;
        await LoadTicketsAsync(BuildCurrentCriteria());
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || (totalPages > 0 && page > totalPages) || page == currentPage)
        {
            return;
        }

        currentPage = page;
        await LoadTicketsAsync(BuildCurrentCriteria());
    }

    private async Task LoadTicketsAsync(TicketSearchCriteria? criteria = null)
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await TicketService.GetTicketsAsync(criteria ?? BuildCurrentCriteria());
            tickets.Clear();
            tickets.AddRange(result.Items);
            totalCount = result.TotalCount;
            totalPages = result.TotalPages;
            currentPage = result.CurrentPage;
        }
        catch (ApiClientException ex)
        {
            errorMessage = ex.Message;
            Notifications.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to reach the API at the configured base URL. Ensure TicketSystem.Api is running on http://localhost:5041. ({ex.Message})";
            Notifications.ShowError(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }

    private TicketSearchCriteria BuildCurrentCriteria() => new()
    {
        Keyword = currentKeyword,
        Status = currentStatus,
        Priority = currentPriority,
        SortBy = currentSortBy,
        SortDirection = currentSortDirection,
        AssignedToId = currentAssigneeSelection is not null and not "all" and not "unassigned" && int.TryParse(currentAssigneeSelection, out var userId)
            ? userId
            : null,
        UnassignedOnly = currentAssigneeSelection == "unassigned",
        PageNumber = currentPage,
        PageSize = pageSize
    };
}
